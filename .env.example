# Next.js warehouse app environment variables
NEXT_PUBLIC_APP_NAME=WarehouseApp
NEXT_PUBLIC_API_URL=https://api.warehouseapp.local
NEXT_PUBLIC_WS_URL=wss://api.warehouseapp.local/realtime
NEXT_PUBLIC_STORAGE_BUCKET=warehouse-assets
NEXT_PUBLIC_APP_NAME=Paces
NEXT_PUBLIC_SESSION_DURATION_MINUTES=30

DATABASE_URL=postgresql://warehouse_user:warehouse_pass@localhost:5432/warehouse_db
MONGODB_URI=mongodb://localhost:27017/warehouse_db
MYSQL_URL=mysql://warehouse_user:warehouse_pass@localhost:3306/warehouse_db
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_secure_secret

WAREHOUSE_ENV=development
WAREHOUSE_REGION=us-east-1
LOG_LEVEL=debug

BETTER_AUTH_SECRET=auth_secret_key_here
NEXTAUTH_SECRET=auth_secret_key_here
NEXTAUTH_URL=http://localhost:3000

